rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Plausibility floor + upper cap. These two literals MUST equal
    // MIN_VALID_SCORE_TIME / MAX_VALID_SCORE_TIME in src/score-limits.ts — Firestore
    // rules cannot import JS, so the values are duplicated and kept in lockstep by the
    // drift test in tests/score-limits-sync-tests.js. The floor (18 s) was measured
    // empirically (issue #229, PR A): the shipped engine cannot produce a faster run, so
    // a sub-floor write is forged and the server rejects it even from a patched client.
    function isValidScoreTime(time) {
      return time is number && time >= 18 && time <= 600;
    }

    function userDocPath(userId) {
      return /databases/$(database)/documents/users/$(userId);
    }

    // Per-difficulty best-time fields. `bestTime` is the Blue tier (unchanged);
    // bestTimeBunny / bestTimeBlack / bestTimeExpert are the other tiers. All validate
    // against the same plausibility floor for now (every tier currently plays the same
    // physics).
    //
    // VERSIONED fields (#403 review tail): a PHYSICS_VERSION bump makes times
    // incomparable across versions, so the ACTIVE fields carry a V<N> suffix
    // (userBestTimeField in src/difficulty.ts — the lockstep is enforced by
    // tests/remote-version-sync-tests.js). The unversioned fields remain accepted
    // so still-deployed pre-bump clients keep working; they become the historical
    // record the moment the versioned client is serving.
    function validUserKeys(data) {
      return data.keys().hasOnly([
        'displayName',
        'email',
        'photoURL',
        'lastLogin',
        'bestTime',
        'bestTimeBunny',
        'bestTimeBlack',
        'bestTimeExpert',
        'bestTimeV3',
        'bestTimeBunnyV3',
        'bestTimeBlackV3',
        'bestTimeExpertV3',
        'updatedAt'
      ]);
    }

    function validUserDoc(data) {
      return validUserKeys(data)
        && (!('displayName' in data) || data.displayName == null || data.displayName is string)
        && (!('email' in data) || data.email == null || data.email is string)
        && (!('photoURL' in data) || data.photoURL == null || data.photoURL is string)
        && (!('lastLogin' in data) || data.lastLogin is timestamp)
        && (!('bestTime' in data) || isValidScoreTime(data.bestTime))
        && (!('bestTimeBunny' in data) || isValidScoreTime(data.bestTimeBunny))
        && (!('bestTimeBlack' in data) || isValidScoreTime(data.bestTimeBlack))
        && (!('bestTimeExpert' in data) || isValidScoreTime(data.bestTimeExpert))
        && (!('bestTimeV3' in data) || isValidScoreTime(data.bestTimeV3))
        && (!('bestTimeBunnyV3' in data) || isValidScoreTime(data.bestTimeBunnyV3))
        && (!('bestTimeBlackV3' in data) || isValidScoreTime(data.bestTimeBlackV3))
        && (!('bestTimeExpertV3' in data) || isValidScoreTime(data.bestTimeExpertV3))
        && (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function changedUserKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function validChangedUserFields() {
      return validUserKeys(request.resource.data)
        && changedUserKeys().hasOnly([
          'displayName',
          'email',
          'photoURL',
          'lastLogin',
          'bestTime',
          'bestTimeBunny',
          'bestTimeBlack',
          'bestTimeExpert',
          'bestTimeV3',
          'bestTimeBunnyV3',
          'bestTimeBlackV3',
          'bestTimeExpertV3',
          'updatedAt'
        ])
        && (!changedUserKeys().hasAny(['displayName']) ||
          request.resource.data.displayName == null ||
          request.resource.data.displayName is string)
        && (!changedUserKeys().hasAny(['email']) ||
          request.resource.data.email == null ||
          request.resource.data.email is string)
        && (!changedUserKeys().hasAny(['photoURL']) ||
          request.resource.data.photoURL == null ||
          request.resource.data.photoURL is string)
        && (!changedUserKeys().hasAny(['lastLogin']) ||
          request.resource.data.lastLogin is timestamp)
        && (!changedUserKeys().hasAny(['updatedAt']) ||
          request.resource.data.updatedAt is timestamp);
    }

    // Each per-tier best-time field, if changed, must be plausible and may not be
    // downgraded to a slower time (mirrors the original Blue-only check per field).
    // Each clause's `||` short-circuits so a field's value is only read when it changed
    // (and is therefore present), matching the original safe-access pattern.
    function validBestTimeUpdate() {
      return (
        !changedUserKeys().hasAny(['bestTime'])
        || (
          isValidScoreTime(request.resource.data.bestTime)
          && (!('bestTime' in resource.data) ||
            !isValidScoreTime(resource.data.bestTime) ||
            request.resource.data.bestTime <= resource.data.bestTime)
        )
      ) && (
        !changedUserKeys().hasAny(['bestTimeBunny'])
        || (
          isValidScoreTime(request.resource.data.bestTimeBunny)
          && (!('bestTimeBunny' in resource.data) ||
            !isValidScoreTime(resource.data.bestTimeBunny) ||
            request.resource.data.bestTimeBunny <= resource.data.bestTimeBunny)
        )
      ) && (
        !changedUserKeys().hasAny(['bestTimeBlack'])
        || (
          isValidScoreTime(request.resource.data.bestTimeBlack)
          && (!('bestTimeBlack' in resource.data) ||
            !isValidScoreTime(resource.data.bestTimeBlack) ||
            request.resource.data.bestTimeBlack <= resource.data.bestTimeBlack)
        )
      ) && (
        !changedUserKeys().hasAny(['bestTimeExpert'])
        || (
          isValidScoreTime(request.resource.data.bestTimeExpert)
          && (!('bestTimeExpert' in resource.data) ||
            !isValidScoreTime(resource.data.bestTimeExpert) ||
            request.resource.data.bestTimeExpert <= resource.data.bestTimeExpert)
        )
      ) && (
        !changedUserKeys().hasAny(['bestTimeV3'])
        || (
          isValidScoreTime(request.resource.data.bestTimeV3)
          && (!('bestTimeV3' in resource.data) ||
            !isValidScoreTime(resource.data.bestTimeV3) ||
            request.resource.data.bestTimeV3 <= resource.data.bestTimeV3)
        )
      ) && (
        !changedUserKeys().hasAny(['bestTimeBunnyV3'])
        || (
          isValidScoreTime(request.resource.data.bestTimeBunnyV3)
          && (!('bestTimeBunnyV3' in resource.data) ||
            !isValidScoreTime(resource.data.bestTimeBunnyV3) ||
            request.resource.data.bestTimeBunnyV3 <= resource.data.bestTimeBunnyV3)
        )
      ) && (
        !changedUserKeys().hasAny(['bestTimeBlackV3'])
        || (
          isValidScoreTime(request.resource.data.bestTimeBlackV3)
          && (!('bestTimeBlackV3' in resource.data) ||
            !isValidScoreTime(resource.data.bestTimeBlackV3) ||
            request.resource.data.bestTimeBlackV3 <= resource.data.bestTimeBlackV3)
        )
      ) && (
        !changedUserKeys().hasAny(['bestTimeExpertV3'])
        || (
          isValidScoreTime(request.resource.data.bestTimeExpertV3)
          && (!('bestTimeExpertV3' in resource.data) ||
            !isValidScoreTime(resource.data.bestTimeExpertV3) ||
            request.resource.data.bestTimeExpertV3 <= resource.data.bestTimeExpertV3)
        )
      );
    }

    // `displayName` is denormalized onto the leaderboard doc at write time because
    // cross-user /users profile reads are (deliberately) denied above — the client
    // cannot resolve other players' names any other way. A free, length-capped
    // string (nullable for providerless sessions) rather than the token's real name:
    // the site offers guest play, so forcing verified full names public would be the
    // worse privacy default. The renderer escapes it on output (src/scores.ts).
    function validLeaderboardKeys(data) {
      return data.keys().hasOnly(['user', 'time', 'achievedAt', 'displayName']);
    }

    function validLeaderboardDoc(userId, data) {
      return validLeaderboardKeys(data)
        && data.user == userDocPath(userId)
        && isValidScoreTime(data.time)
        && (!('achievedAt' in data) || data.achievedAt is timestamp)
        && (!('displayName' in data)
          || data.displayName == null
          || (data.displayName is string && data.displayName.size() <= 40));
    }

    function validLeaderboardUpdate(userId) {
      return validLeaderboardDoc(userId, request.resource.data)
        && (!('time' in resource.data) ||
          !isValidScoreTime(resource.data.time) ||
          request.resource.data.time <= resource.data.time);
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && validUserDoc(request.resource.data);
      allow update: if isOwner(userId) && validChangedUserFields() && validBestTimeUpdate();
      allow delete: if false;
    }

    // The pre-versioning Blue board: still writable so already-deployed pre-v3
    // clients keep working; the versioned client below neither reads nor writes
    // it, so it freezes into the historical record as clients refresh.
    match /leaderboard/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId)
        && exists(userDocPath(userId))
        && validLeaderboardDoc(userId, request.resource.data);
      allow update: if isOwner(userId)
        && exists(userDocPath(userId))
        && validLeaderboardUpdate(userId);
      allow delete: if false;
    }

    // THE ACTIVE Blue board (#403 review tail): version-namespaced alongside
    // userBestTimeField/leaderboardCollectionName in src/difficulty.ts (lockstep
    // enforced by tests/remote-version-sync-tests.js). A PHYSICS_VERSION bump
    // starts a fresh board — pre-bump times were earned on a different surface/
    // clock and must not shadow current-version runs through the monotonic
    // update guard. Same validation as the classic board.
    match /leaderboard_v3/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId)
        && exists(userDocPath(userId))
        && validLeaderboardDoc(userId, request.resource.data);
      allow update: if isOwner(userId)
        && exists(userDocPath(userId))
        && validLeaderboardUpdate(userId);
      allow delete: if false;
    }

    // Per-tier sibling boards (Bunny / Black / Expert). These tiers are currently UNRANKED
    // (difficulty.ts `ranked: false`): reads are allowed (the boards are simply empty),
    // but NO client may write — the unranked guarantee must hold server-side, not just in
    // the finish overlay. The D3 flip-to-ranked PR (after each floor is measured + a
    // winnability gate passes) restores the validated create/update rules the Blue board
    // uses (validLeaderboardDoc / validLeaderboardUpdate, kept above for reuse then).
    match /leaderboard_bunny/{userId} {
      allow get, list: if isSignedIn();
      allow write: if false;
    }

    match /leaderboard_black/{userId} {
      allow get, list: if isSignedIn();
      allow write: if false;
    }

    match /leaderboard_expert/{userId} {
      allow get, list: if isSignedIn();
      allow write: if false;
    }

    // Versioned unranked sibling boards: the versioned client READS these names
    // (empty boards), and the unranked guarantee must hold server-side for the
    // active names exactly as it does for the classic ones above.
    match /leaderboard_v3_bunny/{userId} {
      allow get, list: if isSignedIn();
      allow write: if false;
    }

    match /leaderboard_v3_black/{userId} {
      allow get, list: if isSignedIn();
      allow write: if false;
    }

    match /leaderboard_v3_expert/{userId} {
      allow get, list: if isSignedIn();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
