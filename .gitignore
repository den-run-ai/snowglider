# Dependencies
node_modules/

# IDE files
.DS_Store
.vscode/

# Debug logs
npm-debug.log*

# Test results (generated by CI)
test-results/

# Playwright HTML report (generated by `npm run test:e2e`)
playwright-report/

# GitHub Pages build output
dist/

# Coverage reports (anchored to the repo-root output dir so it does not also
# ignore the tests/coverage/ tooling sources)
/coverage/

# Large video files
*.mov
*.mp4

# Local-only security notes (not for publication)
SECURITY.md

# Firebase emulator debug logs (produced by `npm run test:firebase`)
firestore-debug.log
firebase-debug.log
ui-debug.log

# Firebase service-account / admin SDK keys — live secrets, NEVER commit.
# Rotate immediately if one is ever pushed. These MUST cover every name
# scripts/analytics-report.mjs auto-discovers (its regexes are narrowed to
# exactly these patterns) so a usable key can't sit un-ignored.
*-firebase-adminsdk-*.json
serviceAccount*.json
serviceaccount*.json
*-serviceaccount*.json
*-serviceAccount*.json

# Generated analytics reports (contain player emails/names — never commit)
analytics-out/
